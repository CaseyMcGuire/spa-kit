{
  "name": "@spa-kit/react-relay",
  "version": "0.0.0",
  "description": "Reusable Relay helpers for React",
  "author": "Casey McGuire",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "graphql": ">=15 <=16",
    "react": ">=18",
    "react-dom": ">=18",
    "react-relay": ">=18",
    "relay-runtime": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "graphql-sse": "^2.6.0"
  }
}
